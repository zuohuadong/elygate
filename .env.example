# Elygate Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# PostgreSQL password used by docker-compose*.yml.
# Change this before first Docker startup. Existing database volumes keep the old password.
ELYGATE_DB_PASSWORD=elygate_change_me

# PostgreSQL connection URL for bare-metal/source deployments.
DATABASE_URL=postgresql://dbuser_dba:elygate_change_me@localhost:5432/postgres

# Connection Pool Settings (optimized for PostgreSQL 18.3)
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30
DB_CONNECT_TIMEOUT=10
DB_MAX_LIFETIME=1800
DB_MAX_PIPELINE=200

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# Application port
PORT=3000

# Application environment
NODE_ENV=production

# JWT secret for session tokens (CHANGE IN PRODUCTION)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Better Auth secret
BETTER_AUTH_SECRET=your-better-auth-secret-change-this

# Initial admin password. The gateway syncs this to the `admin` account on startup.
ADMIN_PASSWORD=admin123

# ============================================================
# GATEWAY SETTINGS
# ============================================================

# Enable semantic caching
SEMANTIC_CACHE_ENABLED=true

# Semantic cache similarity threshold (0.0-1.0)
SEMANTIC_CACHE_THRESHOLD=0.95

# Semantic cache TTL in hours
SEMANTIC_CACHE_TTL_HOURS=24

# Log retention in days
LOG_RETENTION_DAYS=7

# ============================================================
# BILLING SETTINGS
# ============================================================

# Billing queue flush interval in milliseconds
BILLING_FLUSH_INTERVAL=1000

# Enable quota pre-deduction
QUOTA_PRE_DEDUCTION=true

# ============================================================
# RATE LIMITING
# ============================================================

# Default rate limit per minute
DEFAULT_RATE_LIMIT=300

# Rate limit window in milliseconds
RATE_LIMIT_WINDOW=60000

# ============================================================
# CIRCUIT BREAKER
# ============================================================

# Error threshold before disabling channel
CIRCUIT_BREAKER_THRESHOLD=3

# Health check interval in milliseconds
HEALTH_CHECK_INTERVAL=60000

# ============================================================
# NOTIFICATION SETTINGS
# ============================================================

# Enable notifications
NOTIFICATIONS_ENABLED=true

# Notification webhook URL (optional)
NOTIFICATION_WEBHOOK_URL=

# ============================================================
# MONITORING SETTINGS
# ============================================================

# Enable performance monitoring
MONITORING_ENABLED=true

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable request logging
REQUEST_LOGGING=true

# ============================================================
# SECURITY SETTINGS
# ============================================================

# Enable SSL for database connections
DB_SSL_ENABLED=false

# Database CA certificate (for SSL)
DB_CA_CERT=

# Enable CORS
CORS_ENABLED=true

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=*

# ============================================================
# CACHE SETTINGS
# ============================================================

# Cache refresh interval in milliseconds
CACHE_REFRESH_INTERVAL=60000

# Enable multi-instance cache sync
CACHE_SYNC_ENABLED=true

# ============================================================
# OAUTH SETTINGS (Optional)
# ============================================================

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Telegram OAuth
TELEGRAM_BOT_TOKEN=

# ============================================================
# PAYMENT SETTINGS (Optional)
# ============================================================

# Payment provider
PAYMENT_PROVIDER=stripe

# Stripe API key
STRIPE_API_KEY=

# Stripe webhook secret
STRIPE_WEBHOOK_SECRET=

# ============================================================
# LOGGING SETTINGS
# ============================================================

# Enable file logging
FILE_LOGGING=true

# Log file path
LOG_FILE_PATH=./logs/elygate.log

# Log rotation size in MB
LOG_ROTATION_SIZE=100

# Log retention days
LOG_RETENTION_DAYS=30

# ============================================================
# PERFORMANCE TUNING
# ============================================================

# Maximum concurrent upstream requests
MAX_CONCURRENT_REQUESTS=100

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Stream buffer size in KB
STREAM_BUFFER_SIZE=64

# ============================================================
# DEVELOPMENT SETTINGS
# ============================================================

# Enable debug mode
DEBUG=false

# Enable hot reload
HOT_RELOAD=false

# Enable API documentation
API_DOCS_ENABLED=true

# ============================================================
# PRODUCTION CHECKLIST
# ============================================================

# Before deploying to production, ensure:
# 1. Change all secrets and keys
# 2. Enable SSL for database connections
# 3. Configure proper CORS origins
# 4. Set up monitoring and logging
# 5. Configure backup strategy
# 6. Set up rate limiting
# 7. Enable notifications
# 8. Configure OAuth providers
# 9. Set up payment integration
# 10. Test all functionality

# ============================================================
# NEW API PARITY - EMAIL & CAPTCHA
# ============================================================

# SMTP email configuration (JSON in options table or env)
# Example: {"host":"smtp.gmail.com","port":587,"username":"you@gmail.com","password":"app-password","from":"you@gmail.com","fromName":"Elygate"}

# Captcha provider: turnstile | recaptcha | hcaptcha | none
CAPTCHA_PROVIDER=none
# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# reCAPTCHA
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# hCaptcha
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# ============================================================
# NEW API PARITY - OAUTH PROVIDERS
# ============================================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# LinuxDo OAuth
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=http://localhost:3000/api/auth/linuxdo/callback

# WeChat OAuth
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback

# ============================================================
# NEW API PARITY - PAYMENT PROVIDERS
# ============================================================

# Creem payment
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRODUCT_ID=

# Waffo payment
WAFFO_API_KEY=
WAFFO_WEBHOOK_SECRET=
WAFFO_MERCHANT_ID=

# ============================================================
# NEW API PARITY - CODEX OAUTH (io.net)
# ============================================================

CODEX_OAUTH_CLIENT_ID=
CODEX_OAUTH_CLIENT_SECRET=
CODEX_OAUTH_REDIRECT_URI=http://localhost:3000/api/admin/channel/codex/oauth/callback

# ============================================================
# FILES & BATCHES
# ============================================================

# Maximum file upload size in MB (default: 50)
MAX_FILE_SIZE=50

# Internal token for batch processing (optional)
BATCH_INTERNAL_TOKEN=
