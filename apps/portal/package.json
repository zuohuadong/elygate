    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@elygate/db": "workspace:*",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "postcss": "^8.5.14",
