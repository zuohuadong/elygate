{
  "name": "pgredis",
  "version": "0.1.0",
  "description": "PostgreSQL-backed Redis feature replacement toolkit: KV/TTL cache, pub/sub, advisory locks, rate limiting, and pg-boss queues",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*",
    "README.md"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test src/*.test.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@elygate/pg-kv-cache": "workspace:*",
    "@elygate/pg-listen": "workspace:*",
    "pg-boss": "^12.18.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
