{
    "name": "@elygate/db",
    "version": "0.3.4",
    "type": "module",
    "main": "./src/index.ts",
    "scripts": {
        "db:generate": "bun run ./src/new-migration.ts",
        "db:migrate": "bun run ./src/migrate.ts",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio"
    },
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./schema": {
            "types": "./src/schema.ts",
            "import": "./src/schema.ts"
        },
        "./operators": {
            "types": "./src/operators.ts",
            "import": "./src/operators.ts"
        }
    },
    "types": "./src/index.ts",
    "dependencies": {
        "@svadmin/drizzle": "0.11.1",
        "drizzle-orm": "1.0.0-rc.4-273829f",
        "refine-sqlx": "0.10.3"
    },
    "devDependencies": {
        "drizzle-kit": "^0.31.10"
    }
}
