{
  "name": "@elygate/pg-kv-cache",
  "version": "0.1.0",
  "description": "Bun.SQL-backed PostgreSQL KV/TTL cache with local L1 caching",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/**/*"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test src/*.test.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
