# ─── Production Web Admin (Svelte + Vite) Dockerfile ───────────
FROM oven/bun:1-alpine AS builder
WORKDIR /app

# Install all deps (including dev) for build
COPY package.json bun.lock* bun.lockb* tsconfig.json ./
COPY apps/gateway/package.json ./apps/gateway/
COPY apps/portal/package.json ./apps/portal/
COPY apps/admin/package.json ./apps/admin/
COPY apps/enterprise-console/package.json ./apps/enterprise-console/
COPY packages/db/package.json ./packages/db/
COPY packages/enterprise-adapter/package.json ./packages/enterprise-adapter/
COPY packages/enterprise-authz/package.json ./packages/enterprise-authz/
COPY packages/enterprise-contracts/package.json ./packages/enterprise-contracts/
COPY packages/pg-listen/package.json ./packages/pg-listen/
COPY packages/svadmin-core/package.json ./packages/svadmin-core/
COPY packages/svadmin-editor/package.json ./packages/svadmin-editor/
COPY packages/svadmin-elysia/package.json ./packages/svadmin-elysia/
COPY packages/svadmin-helpers/package.json ./packages/svadmin-helpers/
COPY packages/svadmin-simple-rest/package.json ./packages/svadmin-simple-rest/
COPY packages/svadmin-ui/package.json ./packages/svadmin-ui/

RUN bun install

# Copy source and build the admin console
COPY apps/admin ./apps/admin
COPY packages ./packages

WORKDIR /app/apps/admin
RUN bun run build

# ─── Production runtime ─────────────────────────────────────
FROM oven/bun:1-alpine AS runner
WORKDIR /app

COPY --from=builder /app/apps/admin/dist ./dist
COPY docker/serve-static.ts ./serve-static.ts

EXPOSE 3001
ENV NODE_ENV=production PORT=3001

CMD ["bun", "serve-static.ts"]
