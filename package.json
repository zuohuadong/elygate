{
  "name": "elygate",
  "version": "0.1.6",
  "description": "AI API 批发平台",
  "private": true,
  "scripts": {
    "dev": "bun --cwd apps/gateway dev & bun --cwd apps/web dev",
    "build": "bun --cwd apps/web build",
    "start": "bun --cwd apps/gateway start & bun --cwd apps/web start",
    "build:binary": "bun run scripts/build-binary.ts",
    "build:binary:linux-x64": "bun run scripts/build-binary.ts -- --platform linux-x64",
    "build:binary:linux-arm64": "bun run scripts/build-binary.ts -- --platform linux-arm64",
    "build:binary:darwin-x64": "bun run scripts/build-binary.ts -- --platform darwin-x64",
    "build:binary:darwin-arm64": "bun run scripts/build-binary.ts -- --platform darwin-arm64",
    "build:binary:windows": "bun run scripts/build-binary.ts -- --platform windows-x64",
    "changelog": "bun run scripts/changelog.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  }
}